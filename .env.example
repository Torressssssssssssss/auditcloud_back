# ============================================================
# Servidor
# ============================================================
# Opcional
# Default en codigo: 3000
PORT=3000

# ============================================================
# Frontend / CORS
# ============================================================
# Opcional
# Default en codigo: http://localhost:4200 para Mercado Pago
# Nota: usar un solo origen principal; CORS ya incluye defaults locales.
FRONTEND_URL=http://localhost:4200

# ============================================================
# MySQL Maestro
# ============================================================
# Obligatoria para flujos MySQL
DB_HOST=192.168.30.1

# Obligatoria para flujos MySQL
DB_PORT=3306

# Obligatoria para flujos MySQL
DB_USER=auditcloud_app

# Obligatoria para flujos MySQL
DB_PASSWORD=change_me

# Obligatoria para flujos MySQL
DB_NAME=auditcloud_db

# Opcional
# Default en codigo: 10
DB_CONNECTION_LIMIT=10

# ============================================================
# Autenticacion / JWT
# ============================================================
# Obligatoria recomendada
# Default en codigo: secreto_super_seguro_para_token
JWT_SECRET=change_me

# ============================================================
# PayPal
# ============================================================
# Obligatoria para usar PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id

# Obligatoria para usar PayPal
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Obligatoria para usar PayPal
PAYPAL_API=https://api-m.sandbox.paypal.com

# ============================================================
# Mercado Pago
# ============================================================
# Obligatoria para usar Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token

# Opcional
# Default en codigo: https://api.mercadopago.com
MERCADOPAGO_API=https://api.mercadopago.com

# ============================================================
# Elasticsearch
# ============================================================
# Opcional
# Default en codigo: false
ELASTICSEARCH_ENABLED=true

# Opcional
# Default en codigo: http://192.168.30.11:9200
ELASTICSEARCH_NODE=http://192.168.30.11:9200

# Opcional
# Default en codigo: auditcloud_auditorias
ELASTICSEARCH_INDEX_AUDITORIAS=auditcloud_auditorias

# Opcional
# Dejar vacio si Elasticsearch no usa autenticacion.
ELASTICSEARCH_USERNAME=

# Opcional
# Dejar vacio si Elasticsearch no usa autenticacion.
ELASTICSEARCH_PASSWORD=

# Opcional
# Default en codigo: 100
ELASTICSEARCH_REINDEX_BATCH_SIZE=100

# ============================================================
# Kibana solo referencia visual
# ============================================================
# Opcional
# No usada por el backend para guardar datos. Kibana solo visualiza Elasticsearch.
KIBANA_URL=http://192.168.30.11:5601

# ============================================================
# Email / SMTP
# ============================================================
# Opcional
# Si falta EMAIL_USER o EMAIL_PASS, el servicio de email se deshabilita.
EMAIL_USER=

# Opcional
# Si falta EMAIL_USER o EMAIL_PASS, el servicio de email se deshabilita.
EMAIL_PASS=

# ============================================================
# Firebase Storage
# ============================================================
# Opcional
# JSON serializado de service account. Alternativa a FIREBASE_SERVICE_ACCOUNT_PATH.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Opcional
# Default alternativo en codigo: ./serviceAccountKey.json si existe.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Opcional
# Default en codigo: <project_id>.appspot.com si hay credenciales.
FIREBASE_STORAGE_BUCKET=

# ============================================================
# Variables posiblemente obsoletas / no usadas directamente
# ============================================================
# KIBANA_URL se documenta solo como referencia operativa.
# El backend no debe escribir datos en Kibana ni usar el puerto 5601.
